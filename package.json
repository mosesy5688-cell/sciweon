{
  "name": "sciweon",
  "version": "0.5.0-alpha",
  "description": "Data infrastructure for AI agents - cross-domain structured intelligence",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "harvest:pubchem": "node scripts/factory/pubchem-harvester.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "ces": "python3 scripts/check_compliance.py",
    "ces-check": "python3 scripts/check_compliance.py",
    "ces:strict": "CES_ENGLISH_STRICT=1 python3 scripts/check_compliance.py",
    "audit": "npm audit --audit-level=high",
    "snapshot": "node scripts/factory/snapshot-builder.js",
    "snapshot:upload": "node scripts/factory/snapshot-uploader.js",
    "snapshot:download": "node scripts/factory/snapshot-downloader.js",
    "health": "node scripts/factory/source-health-monitor.js",
    "health:upload": "node scripts/factory/health-report-uploader.js",
    "stage:1": "node scripts/factory/stage-1-harvest.js",
    "stage:2": "node scripts/factory/stage-2-process.js",
    "stage:3": "node scripts/factory/stage-3-aggregate.js",
    "stage:4": "node scripts/factory/stage-4-upload.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "astro": "^6.3.2",
    "dotenv": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.90.1"
  },
  "engines": {
    "node": ">=22"
  }
}
